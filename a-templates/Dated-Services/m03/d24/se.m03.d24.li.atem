Template se.m03.d24.li

Status NA

	import da.*
	import oc.*
	import me.*
	import eo.*
	import tr.*
	import pe.*

	import actors_gr_GR_cog.*
	import dismissals_gr_GR_cog.*
	import miscellanea_gr_GR_cog.*
	import prayers_gr_GR_cog.*
	import rubrical_gr_GR_cog.*
	import template.titles_gr_GR_cog.*
	import titles_gr_GR_cog.*

	import iTags.*
	import bTags.*
	import roles.*

	Head
		Set_Date month 3 day 24 year 2026 End_Date
			Page_Header_Even
				center @lookup sid template.titles_gr_GR_cog.li4.pdf.header lang L1 @lookup rid daOnDay.text lang L1 @lookup rid meDA.pdfheaderdate lang L1
			End_Page_Header_Even
			Page_Header_Odd
				center @lookup sid template.titles_gr_GR_cog.li4.pdf.header lang L2 @lookup rid daOnDay.text lang L2 @lookup rid meDA.pdfheaderdate lang L2
			End_Page_Header_Odd
			Page_Footer_Even
				left @pageNbr
				right @lookup sid pdf.covers_en_US_goarch.footer.attribution.text lang L2
			End_Page_Footer_Even
			Page_Footer_Odd
				left @lookup sid pdf.covers_en_US_goarch.footer.attribution.text lang L2
				right @pageNbr
			End_Page_Footer_Odd
		Set_Page_Number 1 End_Set_Page_Number
	End_Head

	Preface Covers
		Insert_template pdf.cover.li.me End-Insert
		Insert_template pdf.cover.credits End-Insert
	End-Preface

	when-movable-cycle-day-is
		28 use:
			Section Instance03
				Insert_section ST.li.me1_tr End-Insert
				Insert_section LI._01_Enarxis__.daily End-Insert
				Insert_section LI._02_Antiphons__.celebrated_saint End-Insert
				Insert_section AP.tr1_ End-Insert
				Insert_section LI._04_Entrance__.choir End-Insert
				Insert_section LI._05_AfterEntranceHymns__.choir End-Insert
				Section hymns
					Insert_section TI.a.me.com1 End-Insert
					Insert_section AP.me1_.hymn End-Insert
					Insert_section LI._05_AfterEntranceHymns__.apolytikion2 End-Insert
					Insert_section TI.tr.com1 End-Insert
					Insert_section AP.tr1_.hymn End-Insert
					Insert_section LI._05_AfterEntranceHymns__.local_rubric End-Insert
					Insert_section KO.seasonal End-Insert
				End-Section
				Insert_section LI._06_Trisagion__.chrys End-Insert
				Para role brc_li_epistle sid misc.custcontent End-Para
					Insert_section TI.le.ep.s._00_saint_.m End-Insert
					Insert_section LE._01_Epistle__.daily_.prokeimenon End-Insert
					Insert_section LE._01_Epistle__.martyr_.lesson End-Insert
				Para role erc_li_epistle sid misc.custcontent End-Para
				Para role brc_li_gospel sid misc.custcontent End-Para
					Insert_section LE._02_Gospel__.daily_ End-Insert
				Para role erc_li_gospel sid misc.custcontent End-Para
				Insert_section LI._08_Liturgy__.chrys_default End-Insert
				Insert_section LI.kollyva_prayer__.tr End-Insert
				Insert_section LI._09_Dismissal__.commemoration End-Insert
			End-Section

		29, 43 use:
			Section Instance04 //2024
				Insert_section mc.map.li.Instance01 End-Insert
			End-Section

		35 use:
			Section Instance10 //2035 trd036
				Break line End_Break
				Rubric sid tr.d035_gr_GR_cog.trR001 End-Rubric
				Break line End_Break
				Section block1
					Para role servicesourcestitle sid misc.book.BooksSources.title End-Para
					Para role servicesources sid misc.book.Triodion.name End-Para
					Insert_section Selector_ServiceTitle.tr_on_day End-Insert
					Set_mcDay day 36 End_mcDay
					Insert_section Selector_ServiceTitle.tr_on_day End-Insert
					Set_mcDay day 0 End_mcDay
					Para role servicesources sid misc.book.Menaion.name sid misc.separator.hyphen rid meDA.date End-Para
					Para role servicesourcessection rid meDA.commemoration.first_short End-Para
					Title sid misc.horizontal_line.solid1 End-Title
					Break line End_Break
					Title<bnr>sid li.html.tab</>End-Title
					Insert_section ST.copyright_notice__.goa_liturgy_chrys End-Insert
				End-Section
				Insert_section LI._01_Enarxis__.daily End-Insert
				Insert_section LI._02_Antiphons__.celebrated_saint End-Insert
				Set_mcDay day 36 End_mcDay
				Insert_section AP.tr1_ End-Insert
				Set_mcDay day 0 End_mcDay
				Insert_section LI._04_Entrance__.choir End-Insert
				Insert_section LI._05_AfterEntranceHymns__.choir End-Insert
				Section hymns
					Insert_section TI.a.me.com1 End-Insert
					Insert_section AP.me1_.hymn End-Insert
					Insert_section LI._05_AfterEntranceHymns__.apolytikion2 End-Insert
					Set_mcDay day 36 End_mcDay
					Insert_section TI.tr.com1 End-Insert
					Insert_section AP.tr1_.hymn End-Insert
					Set_mcDay day 35 End_mcDay
					Insert_section LI._05_AfterEntranceHymns__.local_rubric End-Insert
					Insert_section KO.seasonal End-Insert
				End-Section
				Insert_section LI._06_Trisagion__.chrys End-Insert
				Set_Date month 11 day 13 year 2026 End_Date
				Para role brc_li_epistle sid misc.custcontent End-Para
					Insert_section LE._01_Epistle__.menaion_ End-Insert
				Para role erc_li_epistle sid misc.custcontent End-Para
				Para role brc_li_gospel sid misc.custcontent End-Para
					Insert_section LE._02_Gospel__.menaion_ End-Insert
				Para role erc_li_gospel sid misc.custcontent End-Para
				Insert_section LI._08_Liturgy__.chrys_default End-Insert
				Set_Date month 3 day 24 year 2026 End_Date
				Insert_section LI._09_Dismissal__.commemoration End-Insert
			End-Section

		otherwise use: // I had to insert this logic, otherwise the template would not process day 35 correctly.
			when-movable-cycle-day-is
			36, 50, 57 use:
				Section Instance11 //2019, 2030
					Insert_section ST.li.ba.oc_tr_me1 End-Insert
					Insert_section LI._01_Enarxis__.daily End-Insert
					Insert_section LI._02_Antiphons__.sundays_weekdays_feasts End-Insert
					Insert_section LI._04_Entrance__.choir End-Insert
					Insert_section LI._05_AfterEntranceHymns__.choir End-Insert
					Section hymns
						Insert_section AP.res__.modeofweek End-Insert
						Insert_section LI._05_AfterEntranceHymns__.apolytikion2 End-Insert
						Insert_section TI.bf End-Insert
						Insert_section AP.me1_.hymn End-Insert
						Insert_section TI.tr.com1 End-Insert
						Insert_section AP.tr1_.hymn End-Insert
						Insert_section LI._05_AfterEntranceHymns__.local_rubric End-Insert
						Insert_section TI.k.bf End-Insert
						Insert_section KO.meli_k1_.hymn End-Insert
					End-Section
					Insert_section LI._06_Trisagion__.basil End-Insert
					Para role brc_li_epistle sid misc.custcontent End-Para
						Insert_section LE._01_Epistle__.daily_ End-Insert
					Para role erc_li_epistle sid misc.custcontent End-Para
					Para role brc_li_gospel sid misc.custcontent End-Para
						Insert_section LE._02_Gospel__.daily_ End-Insert
					Para role erc_li_gospel sid misc.custcontent End-Para
					Insert_section LI._08_Liturgy__.basil End-Insert
					Insert_section LI._09_Dismissal__.commemoration End-Insert
				End-Section
	
			42 use:
				Section Instance13 //2063
					Rubric sid misc.FutureInstance End-Rubric
				End-Section
	
			49 use:
				Section Instance17 //2012, 2085
					Insert_section Instance13 End-Insert
				End-Section
	
			56 use:
				Section Instance22
					Insert_section ST.li.me1_tr End-Insert
					Insert_section LI._01_Enarxis__.daily End-Insert
					Insert_section LI._02_Antiphons__.sundays_weekdays_feasts End-Insert
					Insert_section LI._04_Entrance__.choir End-Insert
					Section hymns
						Insert_section AP.tr1_ End-Insert
						Insert_section LI._05_AfterEntranceHymns__.apolytikion2 End-Insert
						Insert_section TI.bf End-Insert
						Insert_section AP.me1_.hymn End-Insert
						Insert_section LI._05_AfterEntranceHymns__.local_rubric End-Insert
						Insert_section TI.k.bf End-Insert
						Insert_section KO.me1_.hymn End-Insert
					End-Section
					Insert_section LI._06_Trisagion__.chrys End-Insert
					Para role brc_li_epistle sid misc.custcontent End-Para
						Insert_section LE._01_Epistle__.triodion__.d056_akathist End-Insert
					Para role erc_li_epistle sid misc.custcontent End-Para
					Para role brc_li_gospel sid misc.custcontent End-Para
						Insert_section LE._02_Gospel__.triodion__.d056_akathist End-Insert
					Para role erc_li_gospel sid misc.custcontent End-Para
					Insert_section LI._08_Liturgy__.chrys_default End-Insert
					Insert_section LI._09_Dismissal__.commemoration End-Insert
				End-Section
	
		end-when
	end-when

End-Template