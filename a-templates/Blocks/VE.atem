		Section oc__
			Section weekday_
				Section aposticha
					when-name-of-day-is
						Saturday use:
							Section saturday
								Para role bkmrk05 sid misc.bookmark End-Para
								Title role desig sid ti.ApostichaOctoechos End-Title
								Para role source0 sid ti.sourceOctoechos End-Para
								when-exists
									rid ocVE.Aposticha1.melody use:
										Title role mode rid ocVE.Aposticha1.mode<Tmelody>rid ocVE.Aposticha1.melody</>End-Title
										Title role greekmelody rid ocVE.Aposticha1.greekmelody End-Title
									otherwise use:
										Title role mode rid ocVE.Aposticha1.mode End-Title
								end-when
								Media rid ocVE.Aposticha1.text End-Media
								Hymn rid ocVE.Aposticha1.text @ver media-off End-Hymn
								Media rid ocVE.Aposticha2.text End-Media
								Insert_section PsalmVerses.forVespersAposticha.friday.verse1 End-Insert
								when-exists rid ocVE.Aposticha2.melody use:
									Title role melody rid ocVE.Aposticha2.melody End-Title
									Title role greekmelody rid ocVE.Aposticha2.greekmelody End-Title
								end-when
								Hymn rid ocVE.Aposticha2.text @ver media-off End-Hymn
								Media rid ocVE.Aposticha3.text End-Media
								Insert_section PsalmVerses.forVespersAposticha.friday.verse2 End-Insert
								when-exists rid ocVE.Aposticha3.melody use:
									Title role melody rid ocVE.Aposticha3.melody End-Title
									Title role greekmelody rid ocVE.Aposticha3.greekmelody End-Title
								end-when
								Hymn rid ocVE.Aposticha3.text @ver media-off End-Hymn
								when-exists rid ocVE.Aposticha4.text use:
									Media rid ocVE.Aposticha4.text End-Media
									Insert_section PsalmVerses.forVespersAposticha.friday.verse3 End-Insert
									Hymn rid ocVE.Aposticha4.text @ver media-off End-Hymn
								end-when
							End-Section
						otherwise use:
							Section montuewedthufri
								Para role bkmrk05 sid misc.bookmark End-Para
								Title role desig sid ti.ApostichaOctoechos End-Title
								Para role source0 sid ti.sourceOctoechos End-Para
								when-exists
									rid ocVE.Aposticha1.melody use:
										Title role mode rid ocVE.Aposticha1.mode<Tmelody>rid ocVE.Aposticha1.melody</>End-Title
										Title role greekmelody rid ocVE.Aposticha1.greekmelody End-Title
									otherwise use:
										Title role mode rid ocVE.Aposticha1.mode End-Title
								end-when
								Media rid ocVE.Aposticha1.text End-Media
								Hymn rid ocVE.Aposticha1.text @ver media-off End-Hymn
								Media rid ocVE.Aposticha2.text End-Media
								Insert_section PsalmVerses.forVespersAposticha.weekday.verse1 End-Insert
								when-exists rid ocVE.Aposticha2.melody use:
									Title role melody rid ocVE.Aposticha2.melody End-Title
									Title role greekmelody rid ocVE.Aposticha2.greekmelody End-Title
								end-when
								Hymn rid ocVE.Aposticha2.text @ver media-off End-Hymn
								Media rid ocVE.Aposticha3.text End-Media
								Insert_section PsalmVerses.forVespersAposticha.weekday.verse2 End-Insert
								Title role desig sid ti.ForMartyrs_1hymn End-Title
								when-exists rid ocVE.Aposticha3.melody use:
									Title role melody rid ocVE.Aposticha3.melody End-Title
									Title role greekmelody rid ocVE.Aposticha3.greekmelody End-Title
								end-when
								Hymn rid ocVE.Aposticha3.text @ver media-off End-Hymn
							End-Section
					end-when
				End-Section
				Section theotokion
					when-name-of-day-is
						Monday, Tuesday, Thursday, Saturday use:
							Title sid ti.GloryBothNow<Tdesig>sid ti.Theotokion</>End-Title
							when-exists rid ocVE.AposTheotokion.melody use:
								Title role melody rid ocVE.AposTheotokion.melody End-Title
								Title role greekmelody rid ocVE.AposTheotokion.greekmelody End-Title
							end-when
