					End-Section
					Section womanmartyr
						when-name-of-day-is
							Monday, Tuesday, Thursday use:
								Section hymn
									Title sid ti.BothNow<Tdesig>sid ti.Theotokion</>End-Title
									Para role source0 sid ti.sourceOctoechos End-Para
									Title role mode sid misc.Mode6 End-Title
									Insert_section bk.he.o.Theotokion_Vine_WomanMartyr End-Insert
								End-Section
							Wednesday, Friday use:
								when-exists
									rid meVE.SticStavrotheotokion.text use:
										Insert_section VE._03_Stichera__.both__.metheotokion.stavrothetokion End-Insert
									otherwise use:
										Insert_section hymn End-Insert
								end-when
							Saturday use:
								Insert_section VE._03_Stichera__.both__.firsttheotokion__.modeofweek End-Insert
						end-when
					End-Section
