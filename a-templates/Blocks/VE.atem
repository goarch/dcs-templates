	Section Canon_Bookmark_Logic
		when-name-of-day-is
			Sunday use:
			otherwise use:
				when-date-is
					Jan 2 thru 5 use:
						Para role bkmrk06 sid misc.bookmark End-Para
					Mar 25, 26 use:
						when-name-of-day-is
							Saturday use:
								Para role bkmrk07 sid misc.bookmark End-Para
						end-when
					Aug 2 thru 14 use:
						Para role bkmrk08 sid misc.bookmark End-Para
					Dec 20 thru 24 use:
						Para role bkmrk06 sid misc.bookmark End-Para
				end-when	
		end-when
	End-Section

