	Section _03_Stichera__
		Section both__
			Section eucon
				Title sid ti.BothNow<Tdesig>sid ti.Consecration</>End-Title
				Para role source0 sid ti.sourceEuchologion End-Para
				Title role mode sid eu.consecration_gr_GR_cog.euVE.SticBoth.mode End-Title
				Media sid eu.consecration_gr_GR_cog.euVE.SticBoth.text End-Media
				Hymn sid eu.consecration_gr_GR_cog.euVE.SticBoth.text @ver media-off End-Hymn
			End-Section
			Section consecration_clientname
				Title sid ti.BothNow<Tdesig>sid ti.Consecration</>End-Title
				Para role source0 sid ti.sourceEuchologion End-Para
				Title role mode sid eu.consecration_gr_GR_cog.euVE.SticBoth.mode End-Title
				Media sid client_gr_GR_cog.cl.conVE.SticBoth.churchname.text End-Media
				Hymn sid eu.consecration_gr_GR_cog.euVE.SticBoth1.text sid client_gr_GR_cog.cl.conVE.SticBoth.churchname.text media-off sid eu.consecration_gr_GR_cog.euVE.SticBoth2.text @ver media-off End-Hymn
			End-Section
			Section firsttheotokion__
				Section modeofweek
					Title sid ti.BothNow<Tmode>rid ocVE.SticTheotokion.mode @day D1</>End-Title
