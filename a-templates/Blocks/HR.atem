				when-movable-cycle-day-is
					71 thru 109 use:
						Reading sid pe.d071_gr_GR_cog.peMA.Troparion.text @ver media-off End-Reading
					110 thru 120 use:
					otherwise use:
						Reading sid pr.GloryToYouOurGod.text End-Reading
						Reading sid pr.HeavenlyKing.text @ver End-Reading
				end-when
			End-Section
		End-Section
