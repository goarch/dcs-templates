			when-date-is
				Dec 30 use:
					when-movable-cycle-day-is
						//2026
						333 use:
							Insert_section Selector_PreTriodionWeekdaysLectionary.pretriodiongospels__.week_14_thursday End-Insert
						
						//2027
						313 use:
							Insert_section Selector_PreTriodionWeekdaysLectionary.pretriodiongospels__.week_14_friday End-Insert
						
