	Section _16_Aposticha__
		Section both__
			Section me__
				Section bothasboth_
					Title sid ti.BothNow End-Title
					Section hymn
						Para role source0 sid ti.sourceMenaion End-Para
						Title role mode rid meMA.AposBoth.mode End-Title
						Media rid meMA.AposBoth.text End-Media
						Hymn rid meMA.AposBoth.text @ver media-off End-Hymn
					End-Section
				End-Section
				Section theotokion
					when-name-of-day-is
						Wednesday, Friday use:
							Title sid ti.BothNow<Tdesig>sid ti.Stavrotheotokion</>End-Title
							Title role mode rid meMA.AposStavrotheotokion.mode<Tmelody>rid meMA.AposStavrotheotokion.melody</>End-Title
							Title role greekmelody rid meMA.AposStavrotheotokion.greekmelody End-Title
							Media rid meMA.AposStavrotheotokion.text End-Media
							Hymn rid meMA.AposStavrotheotokion.text @ver media-off End-Hymn
						otherwise use:
							Title sid ti.BothNow<Tdesig>sid ti.Theotokion</>End-Title
							Title role mode rid meMA.AposTheotokion.mode<Tmelody>rid meMA.AposTheotokion.melody</>End-Title
							Title role greekmelody rid meMA.AposTheotokion.greekmelody End-Title
							Media rid meMA.AposTheotokion.text End-Media
							Hymn rid meMA.AposTheotokion.text @ver media-off End-Hymn
					end-when
				End-Section
			End-Section
			Section metheotokion
				when-name-of-day-is
					Monday, Tuesday, Thursday, Saturday use:
						Section theotokion
							Title sid ti.BothNow<Tdesig>sid ti.Theotokion</>End-Title
							Title role mode rid meMA.AposTheotokion.mode<Tmelody>rid meMA.AposTheotokion.melody</>End-Title
							Title role greekmelody rid meMA.AposTheotokion.greekmelody End-Title
							Media rid meMA.AposTheotokion.text End-Media
							Hymn rid meMA.AposTheotokion.text @ver media-off End-Hymn
						End-Section
					Wednesday, Friday use:
						when-exists
							rid meMA.AposStavrotheotokion.text use:
								Section stavrotheotokion
									Title sid ti.BothNow<Tdesig>sid ti.Stavrotheotokion</>End-Title
									Title role mode rid meMA.AposStavrotheotokion.mode<Tmelody>rid meMA.AposStavrotheotokion.melody</>End-Title
									Title role greekmelody rid meMA.AposStavrotheotokion.greekmelody End-Title
									Media rid meMA.AposStavrotheotokion.text End-Media
									Hymn rid meMA.AposStavrotheotokion.text @ver media-off End-Hymn
								End-Section
							otherwise use:
								Insert_section theotokion End-Insert
						end-when
				end-when
			End-Section
			Section pe__
				Section gloryasboth_
					Title sid ti.BothNow End-Title
					Section hymn
						Para role source0 sid ti.sourcePentecostarion End-Para
