							Hymn rid alt1.meMA.Exaposteilarion3.text @ver media-off End-Hymn
						End-Section
					end-when
					when-exists rid alt1.meMA.ExapTheotokion.text use:
					Section theotokion
						when-name-of-day-is
							Monday, Tuesday, Thursday, Saturday, Sunday use:
								Section exaptheotokion
									Title role desig sid ti.Theotokion End-Title
									Title role mode rid alt1.meMA.ExapTheotokion.mode<Tmelody>rid alt1.meMA.ExapTheotokion.melody</>End-Title
									Title role greekmelody rid alt1.meMA.ExapTheotokion.greekmelody End-Title
