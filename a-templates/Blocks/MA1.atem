									Hymn rid alt1.meMA.ExapTheotokion.text @ver media-off End-Hymn
								End-Section
							Wednesday, Friday use:
								when-exists rid alt1.meMA.ExapStavrotheotokion.text use:
									Section exapstavrotheotokion
										Title role desig sid ti.Stavrotheotokion End-Title
										Media rid alt1.meMA.ExapStavrotheotokion.text End-Media
										Hymn rid alt1.meMA.ExapStavrotheotokion.text @ver media-off End-Hymn
									End-Section
								otherwise use:
									when-exists rid alt1.meMA.ExapTheotokion.text use:
										Insert_section exaptheotokion End-Insert
									end-when
								end-when
						end-when
