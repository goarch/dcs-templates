	Section _03_Stichera_
		when-name-of-day-is
			Tuesday, Wednesday, Thursday, Friday use:
				Section montuewedthur_
					Section Idiomela_Triodion
						Title role desig sid ti.Triodion End-Title
						Title role desig sid ti.SticheronIdiomelon<Tmode>rid trVE.AposIdiomelon1.mode</>End-Title
						Media rid trVE.AposIdiomelon1.text End-Media
						Insert_section VE.LIHC_Verses.v01 End-Insert
						Hymn rid trVE.AposIdiomelon1.text @ver media-off End-Hymn
						when-movable-cycle-day-is
							47, 51, 52, 53 use:
								Title role desig sid ti.SticheronIdiomelon<Tmode>rid trVE.AposIdiomelon2.mode</>End-Title
								Media rid trVE.AposIdiomelon2.text End-Media
								Insert_section VE.LIHC_Verses.v02 End-Insert
								Hymn rid trVE.AposIdiomelon2.text @ver media-off End-Hymn
							otherwise use:
								Title role desig sid ti.SticheronIdiomelon<Tmode>rid trVE.AposIdiomelon1.mode</>End-Title
								Insert_section VE.LIHC_Verses.v02 End-Insert
								Hymn rid trVE.AposIdiomelon1.text @ver media-off End-Hymn
						end-when
						Title role desig sid ti.ForMartyrs_1hymn End-Title
						Title role mode rid trVE.AposMartyric.mode<Tmelody>rid trVE.AposMartyric.melody</>End-Title
						Media rid trVE.AposMartyric.text End-Media
						Insert_section VE.LIHC_Verses.v03 End-Insert
						Hymn rid trVE.AposMartyric.text @ver media-off End-Hymn
					End-Section
					Section Stichera_Triodion
						Title role desig sid ti.SticheraProsomia sid po.Iosif End-Title
						Title role mode rid trVE.Stichera01.mode<Tmelody>rid trVE.Stichera01.melody</>End-Title
						Media rid trVE.Stichera01.text End-Media
						Insert_section VE.LIHC_Verses.v04 End-Insert
						Hymn rid trVE.Stichera01.text @ver media-off End-Hymn
						Title role mode rid trVE.Stichera02.mode<Tmelody>rid trVE.Stichera02.melody</>End-Title
						Media rid trVE.Stichera02.text End-Media
						Insert_section VE.LIHC_Verses.v05 End-Insert
						Hymn rid trVE.Stichera02.text @ver media-off End-Hymn
						Title role desig sid ti.Another_1hymn sid po.Theodorou End-Title
						Title role mode rid trVE.Stichera03.mode<Tmelody>rid trVE.Stichera03.melody</>End-Title
						Media rid trVE.Stichera03.text End-Media
						Insert_section VE.LIHC_Verses.v06 End-Insert
						Hymn rid trVE.Stichera03.text @ver media-off End-Hymn
					End-Section
					Section Stichera_Menaion
						when-exists
							rid meDA.commemoration.first_title use:
								Insert_section TI.stp.me.com1 End-Insert
							otherwise use:
								Insert_section TI.stp.me._ End-Insert
						end-when
					//	Title<r>ldp @Service_Date ldp</>End-Title
						Insert_section VE._03_Stichera__.me__.p_1123as78910 End-Insert
					End-Section
					Section GloryBoth
						when-movable-cycle-day-is
							47 use:
								Section cross
									Title sid ti.GloryBothNow<Tmode>rid trVE.SticGlory.mode</>End-Title
									Title role desig sid ti.Cross End-Title
									Media rid trVE.SticGlory.text End-Media
									Hymn rid trVE.SticGlory.text @ver media-off End-Hymn
								End-Section
							otherwise use:
								when-name-of-day-is
									Wednesday, Friday use:
										Section stavrotheotokion
											Title sid ti.GloryBothNow<Tdesig>sid ti.Stavrotheotokion</>End-Title
											Title role mode rid meVE.SticStavrotheotokion.mode<Tmelody>rid meVE.SticStavrotheotokion.melody</>End-Title
											Media rid meVE.SticStavrotheotokion.text End-Media
											Hymn rid meVE.SticStavrotheotokion.text @ver media-off End-Hymn
										End-Section
									otherwise use:
										Section theotokion
											Title sid ti.GloryBothNow<Tdesig>sid ti.Theotokion</>End-Title
											Title role mode rid meVE.SticTheotokion.mode<Tmelody>rid meVE.SticTheotokion.melody</>End-Title
											Media rid meVE.SticTheotokion.text End-Media
											Hymn rid meVE.SticTheotokion.text @ver media-off End-Hymn
										End-Section
								end-when
						end-when
					End-Section
				End-Section
			Saturday use:
				Section friday_
					Section Idiomela_Triodion
						Title role desig sid ti.Triodion End-Title
						Title role desig sid ti.SticheronIdiomelon<Tmode>rid trVE.AposIdiomelon1.mode</>End-Title
						Media rid trVE.AposIdiomelon1.text End-Media
						Insert_section VE.LIHC_Verses.v01 End-Insert
						Hymn rid trVE.AposIdiomelon1.text @ver media-off End-Hymn
						when-movable-cycle-day-is
							47, 51, 52, 53 use:
								Title role desig sid misc.Idiomelon<Tmode>rid trVE.AposIdiomelon2.mode</>End-Title
								Insert_section VE.LIHC_Verses.v02 End-Insert
								Media rid trVE.AposIdiomelon2.text End-Media
								Hymn rid trVE.AposIdiomelon2.text @ver media-off End-Hymn
							otherwise use:
								Insert_section VE.LIHC_Verses.v02 End-Insert
								Hymn rid trVE.AposIdiomelon1.text @ver media-off End-Hymn
						end-when
					End-Section
					Section Stichera_Martyric
						Title role desig sid ti.ForMartyrs_hymns End-Title
						Title role mode rid octrVE.Stichera1.mode<Tmelody>rid octrVE.Stichera1.melody</>End-Title
						Media rid octrVE.Stichera1.text End-Media
						Insert_section VE.LIHC_Verses.v03 End-Insert
						Hymn rid octrVE.Stichera1.text @ver media-off End-Hymn
						Title role mode rid octrVE.Stichera2.mode<Tmelody>rid octrVE.Stichera2.melody</>End-Title
						Media rid octrVE.Stichera2.text End-Media
						Insert_section VE.LIHC_Verses.v04 End-Insert
						Hymn rid octrVE.Stichera2.text @ver media-off End-Hymn
						Title role mode rid octrVE.Stichera3.mode<Tmelody>rid octrVE.Stichera3.melody</>End-Title
						Media rid octrVE.Stichera3.text End-Media
						Insert_section VE.LIHC_Verses.v05 End-Insert
