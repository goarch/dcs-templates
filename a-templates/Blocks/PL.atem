					//	Title<r>ldp @Service_Date</>End-Title
						Insert_section VE._03_Stichera__.me__.p_1123as78910 End-Insert
					End-Section
					when-exists
						rid meVE.SticGlory.text use:
							Insert_section VE._03_Stichera__.glory__.me__.gloryasglory_ End-Insert
						otherwise use:
							Section Glory
								Title sid ti.Glory<Tdesig>sid ti.ForDead_1hymn</>End-Title
								Title role mode rid octrVE.SticGlory.mode End-Title
								Media rid octrVE.SticGlory.text End-Media
