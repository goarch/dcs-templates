Template se.den.m05.d30.li9

Status NA

	import da.*
	import oc.*
	import me.*
	import eo.*
	import tr.*
	import pe.*

	import actors_gr_GR_cog.*
	import dismissals_gr_GR_cog.*
	import miscellanea_gr_GR_cog.*
	import prayers_gr_GR_cog.*
	import rubrical_gr_GR_cog.*
	import template.titles_gr_GR_cog.*
	import titles_gr_GR_cog.*

	import iTags.*
	import bTags.*
	import roles.*

	Head
		Set_Date month 5 day 30 year 2026 End_Date
			Page_Header_Even
				center @text "Consecration Liturgy on Saturday, May 30, 2026"
			End_Page_Header_Even
			Page_Header_Odd
				center @text "Consecration Liturgy on Saturday, May 30, 2026"
			End_Page_Header_Odd
			Page_Footer_Even
				left @pageNbr
				right @lookup sid pdf.covers_en_US_goarch.footer.attribution.text lang L2
			End_Page_Footer_Even
			Page_Footer_Odd
				left @lookup sid pdf.covers_en_US_goarch.footer.attribution.text lang L2
				right @pageNbr
			End_Page_Footer_Odd
		Set_Page_Number 1 End_Set_Page_Number
	End_Head

	Preface Covers
		Insert_template pdf.cover.li.override End-Insert
		Insert_template pdf.cover.credits End-Insert
	End-Preface

	Section Instance01
		Insert_section HIRgoa.CONS_LI__.DEN_.block1 End-Insert
		Insert_section CONS.LI_Epistle End-Insert
		Insert_section CONS.LI_Gospel End-Insert
		Insert_section HIRgoa.CONS_LI__.DEN_.block2 End-Insert
		Insert_section CONS.LI_26_CommunionHymn_ End-Insert
		Section block3
			Set_mcDay day 120 End_mcDay
			Insert_section CONS.LI_27 End-Insert
			Set_mcDay day 0 End_mcDay
			Insert_section HIRgoa.LI_09_Dismissal__.DEN End-Insert
		End-Section
	End-Section

End-Template