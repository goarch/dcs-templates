Template pdf.cover.links.lookup

Status NA

	import da.*
	import oc.*
	import me.*
	import eo.*
	import tr.*
	import pe.*

	import actors_gr_GR_cog.*
	import miscellanea_gr_GR_cog.*
	import prayers_gr_GR_cog.*
	import rubrical_gr_GR_cog.*
	import template.titles_gr_GR_cog.*
	import titles_gr_GR_cog.*

	import iTags.*
	import bTags.*
	import roles.*
	import rules.*

	Section vespers
		Title role cover9 sid pdf.covers_gr_GR_cog.vesperalprayers.link.title End-Title
		Title role cover10 sid pdf.covers_gr_GR_cog.Bilingual End-Title
		Title role cover11 sid pdf.covers_gr_GR_cog.vesperalprayers.link.GE End-Title
		Title role cover10 sid pdf.covers_gr_GR_cog.English End-Title
		Title role cover11 sid pdf.covers_gr_GR_cog.vesperalprayers.link.E End-Title
	End-Section

	Section matins
		when-movable-cycle-day-is
			23 use:
				Title role cover9 sid pdf.covers_gr_GR_cog.matinsordinary.link.title End-Title
				Title role cover10 sid pdf.covers_gr_GR_cog.Bilingual End-Title
				Title role cover11 sid pdf.covers_gr_GR_cog.matinsordinary.cleanmonday.link.GE End-Title
				Title role cover10 sid pdf.covers_gr_GR_cog.English End-Title
				Title role cover11 sid pdf.covers_gr_GR_cog.matinsordinary.cleanmonday.link.E End-Title
			24 thru 27 use:
				Section lent
					Title role cover9 sid pdf.covers_gr_GR_cog.matinsordinary.link.title End-Title
					Title role cover10 sid pdf.covers_gr_GR_cog.Bilingual End-Title
					Title role cover11 sid pdf.covers_gr_GR_cog.matinsordinary.lent.link.GE End-Title
					Title role cover10 sid pdf.covers_gr_GR_cog.English End-Title
					Title role cover11 sid pdf.covers_gr_GR_cog.matinsordinary.lent.link.E End-Title
				End-Section
			30 thru 34 use:
				Insert_section lent End-Insert
			37 thru 41 use:
				Insert_section lent End-Insert
			44 thru 48 use:
				Insert_section lent End-Insert
			51 thru 55 use:
				Insert_section lent End-Insert
			58 thru 62 use:
				Insert_section lent End-Insert
			65 thru 77 use:
				Insert_section invisible End-Insert
			78 thru 108 use:
				Title role cover9 sid pdf.covers_gr_GR_cog.matinsordinary.link.title End-Title
				Title role cover10 sid pdf.covers_gr_GR_cog.Bilingual End-Title
				Title role cover11 sid pdf.covers_gr_GR_cog.matinsordinary.paschal.link.GE End-Title
				Title role cover10 sid pdf.covers_gr_GR_cog.English End-Title
				Title role cover11 sid pdf.covers_gr_GR_cog.matinsordinary.paschal.link.E End-Title
			110 thru 120 use:
				Title role cover9 sid pdf.covers_gr_GR_cog.matinsordinary.link.title End-Title
				Title role cover10 sid pdf.covers_gr_GR_cog.Bilingual End-Title
				Title role cover11 sid pdf.covers_gr_GR_cog.matinsordinary.ascension.link.GE End-Title
				Title role cover10 sid pdf.covers_gr_GR_cog.English End-Title
				Title role cover11 sid pdf.covers_gr_GR_cog.matinsordinary.ascension.link.E End-Title
			otherwise use:
				Title role cover9 sid pdf.covers_gr_GR_cog.matinsordinary.link.title End-Title
				Title role cover10 sid pdf.covers_gr_GR_cog.Bilingual End-Title
				Title role cover11 sid pdf.covers_gr_GR_cog.matinsordinary.normal.link.GE End-Title
				Title role cover10 sid pdf.covers_gr_GR_cog.English End-Title
				Title role cover11 sid pdf.covers_gr_GR_cog.matinsordinary.normal.link.E End-Title
		end-when

	End-Section

	Section invisible
		Title role cover90 sid pdf.covers_gr_GR_cog.blank End-Title
		Title role cover110 sid pdf.covers_gr_GR_cog.blank End-Title
		Title role cover110 sid pdf.covers_gr_GR_cog.blank End-Title
		Title role cover110 sid pdf.covers_gr_GR_cog.blank End-Title
		Title role cover110 sid pdf.covers_gr_GR_cog.blank End-Title
	End-Section

End-Template